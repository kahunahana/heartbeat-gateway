# heartbeat-gateway — environment configuration
# Copy to .env and fill in your values:  cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Paths ─────────────────────────────────────────────────────────────────────
GATEWAY_WORKSPACE_PATH=/home/youruser/workspace
GATEWAY_SOUL_MD_PATH=/home/youruser/workspace/SOUL.md

# ── LLM ───────────────────────────────────────────────────────────────────────
# Any LiteLLM model string — see docs/configuration.md for alternatives
GATEWAY_LLM_MODEL=claude-haiku-4-5-20251001

# ── Limits ────────────────────────────────────────────────────────────────────
GATEWAY_HEARTBEAT_MAX_ACTIVE_TASKS=20

# ── Linear ────────────────────────────────────────────────────────────────────
GATEWAY_WATCH__LINEAR__SECRET=your-linear-webhook-secret
# GATEWAY_WATCH__LINEAR__PROJECT_IDS=["proj_abc123","proj_def456"]
# GATEWAY_WATCH__LINEAR__ASSIGNEE_FILTER=any

# ── GitHub ────────────────────────────────────────────────────────────────────
GATEWAY_WATCH__GITHUB__SECRET=your-github-webhook-secret
# GATEWAY_WATCH__GITHUB__REPOS=["owner/repo"]
# GATEWAY_WATCH__GITHUB__BRANCHES=["main"]
# GATEWAY_WATCH__GITHUB__CI_WORKFLOWS=["test","build"]

# ── PostHog ───────────────────────────────────────────────────────────────────
GATEWAY_WATCH__POSTHOG__SECRET=your-posthog-webhook-secret
# GATEWAY_WATCH__POSTHOG__PROJECT_ID=phc_...
# GATEWAY_WATCH__POSTHOG__INSIGHT_IDS=["insight_abc123"]
